# accounts/templates/accounts/profile.html (inline JS)
msgid "File must be an image."
msgstr "يجب أن يكون الملف صورة."

msgid "Image must be 5 MB or smaller."
msgstr "يجب ألا يتجاوز حجم الصورة 5 ميغابايت."

# workspace/templates/workspace/includes/sidebar.html (inline JS)
msgid "Collapse sidebar"
msgstr "طي الشريط الجانبي"

msgid "Expand sidebar"
msgstr "توسيع الشريط الجانبي"

# workspace/static/js/workspace.js
msgid "Create Workspace"
msgstr "إنشاء مشروع"

msgid "Configure RAG"
msgstr "إعداد RAG"

msgid "Done"
msgstr "تم"

msgid "Workspace name is required"
msgstr "اسم المشروع مطلوب"

msgid "Name must be 150 characters or fewer"
msgstr "يجب ألا يتجاوز الاسم 150 حرفاً"

msgid "Please select an answer"
msgstr "يرجى اختيار إجابة"

msgid "Workspace details missing. Please restart."
msgstr "تفاصيل المشروع مفقودة. يرجى إعادة المحاولة."

msgid "Something went wrong"
msgstr "حدث خطأ ما"

msgid "Network error. Please try again."
msgstr "خطأ في الشبكة. حاول مرة أخرى."

msgid "Failed to load."
msgstr "تعذر التحميل."

#, javascript-format
msgid "%(name)s invited you to %(workspace)s"
msgstr "%(name)s دعاك إلى %(workspace)s"

#, javascript-format
msgid "Role: %(role)s"
msgstr "الدور: %(role)s"

msgid "Accept"
msgstr "قبول"

msgid "Reject"
msgstr "رفض"

# workspace/templates/workspace/members.html (inline JS)
msgid "Remove this member from the workspace?"
msgstr "إزالة هذا العضو من المشروع؟"

# documents/templates/documents/Documents.html (inline JS)
msgid "Indexed"
msgstr "مفهرس"

msgid "Pending"
msgstr "قيد المعالجة"

msgid "Loading…"
msgstr "جارٍ التحميل…"

msgid "Workspace not loaded. Please refresh the page."
msgstr "لم يُحمَّل المشروع. يرجى تحديث الصفحة."

msgid "Deleting…"
msgstr "جارٍ الحذف…"

msgid "Failed to delete the file. Please try again."
msgstr "تعذر حذف الملف. حاول مرة أخرى."

msgid "Delete"
msgstr "حذف"

# documents/templates/documents/upload-modal.html (inline JS)
msgid "Ready"
msgstr "جاهز"

msgid "Remove file"
msgstr "إزالة الملف"

msgid "Uploading…"
msgstr "جارٍ الرفع…"

msgid "Uploaded"
msgstr "تم الرفع"

#, javascript-format
msgid "Failed: %(msg)s"
msgstr "فشل: %(msg)s"

msgid "Network error"
msgstr "خطأ في الشبكة"

msgid "Upload failed:"
msgstr "فشل الرفع:"

msgid "Retry"
msgstr "إعادة المحاولة"

# documents/templates/documents/text_input.html (inline JS)
#, javascript-format
msgid "Word Count: %(count)s"
msgstr "عدد الكلمات: %(count)s"

#, javascript-format
msgid "Reading Time: ~%(mins)s min"
msgstr "وقت القراءة: ~%(mins)s دقيقة"

msgid "OK"
msgstr "موافق"

msgid "Cancel"
msgstr "إلغاء"

msgid "Clear editor?"
msgstr "مسح المحرر؟"

msgid "This will remove all content. This cannot be undone."
msgstr "سيؤدي هذا إلى إزالة كل المحتوى. لا يمكن التراجع عن ذلك."

msgid "Clear"
msgstr "مسح"

msgid "Title"
msgstr "العنوان"

msgid "Off"
msgstr "إيقاف"

msgid "Draft saved"
msgstr "تم حفظ المسودة"

msgid "Your draft has been saved successfully."
msgstr "تم حفظ مسودتك بنجاح."

msgid "Published!"
msgstr "تم النشر!"

msgid "Your post has been published successfully."
msgstr "تم نشر منشورك بنجاح."

# workspace/static/js/chat.js
#, javascript-format
msgid "%(count)s Total"
msgstr "الإجمالي: %(count)s"

msgid "What can I help with?"
msgstr "كيف يمكنني المساعدة؟"

msgid "Thinking"
msgstr "يفكر"

msgid "No response."
msgstr "لا يوجد رد."

msgid "New Session"
msgstr "محادثة جديدة"

msgid "Confirm rename"
msgstr "تأكيد إعادة التسمية"

msgid "Cancel rename"
msgstr "إلغاء إعادة التسمية"

msgid "Rename session"
msgstr "إعادة تسمية الجلسة"

msgid "Delete this session? This cannot be undone."
msgstr "حذف هذه الجلسة؟ لا يمكن التراجع."

# workspace/templates/workspace/settings.html (inline JS)
msgid "Regenerating will immediately invalidate the current API key. Continue?"
msgstr "إعادة الإنشاء ستُلغي مفتاح API الحالي فوراً. متابعة؟"

msgid "Generating…"
msgstr "جارٍ الإنشاء…"

#, javascript-format
msgid "Server returned %(status)s: %(text)s"
msgstr "أعاد الخادم %(status)s: %(text)s"

#, javascript-format
msgid "An API key exists for this workspace. Created on %(created)s. Regenerating will immediately invalidate the previous key."
msgstr "يوجد مفتاح API لهذا المشروع. أُنشئ في %(created)s. إعادة الإنشاء ستُلغي المفتاح السابق فوراً."

msgid "Regenerate API key"
msgstr "إعادة إنشاء مفتاح API"

msgid "Generate API key"
msgstr "إنشاء مفتاح API"

#, javascript-format
msgid "Could not generate API key — %(msg)s"
msgstr "تعذر إنشاء مفتاح API — %(msg)s"

msgid "Copied!"
msgstr "تم النسخ!"
